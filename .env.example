# ============================================================================
# OCR Service environment configuration
# Copy to .env and adjust. Never commit a real .env.
# ============================================================================

# --- App ---
OCR_ENV=local                      # local | dev | staging | prod
OCR_LOG_LEVEL=INFO
OCR_LOG_JSON=true                  # false for human-readable logs in local dev
OCR_API_HOST=0.0.0.0
OCR_API_PORT=8000

# --- Database (app role; RLS-enforced) ---
# Async DSN used by the app/worker (asyncpg driver)
OCR_DATABASE_URL=postgresql+asyncpg://ocr_app:changeme_in_production@localhost:5432/ocr
# Sync DSN used by Alembic migrations (privileged role that can create roles/policies)
OCR_MIGRATION_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ocr
OCR_DB_POOL_SIZE=10
OCR_DB_MAX_OVERFLOW=20

# --- Worker pool ---
OCR_WORKER_DEFAULT_CONCURRENCY=10  # per-tenant async concurrency

# --- Auth ---
# RS256 public key (PEM) used to verify JWTs. Multiline -> use \n or mount a file.
OCR_JWT_PUBLIC_KEY_PATH=./deploy/keys/jwt_public.pem
OCR_JWT_ISSUER=ocr-platform
OCR_JWT_AUDIENCE=ocr-api

# --- Qdrant ---
OCR_QDRANT_URL=http://localhost:6333
OCR_QDRANT_API_KEY=
OCR_QDRANT_COLLECTION=ocr_few_shot
OCR_EMBEDDING_DIM=1536

# --- LLM providers ---
# Provider keys use their native names (no OCR_ prefix). Leave blank for Ollama.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provider selection: anthropic | openai | ollama
OCR_LLM_PROVIDER=anthropic
OCR_LLM_PRIMARY_MODEL=claude-sonnet-4-6
OCR_LLM_FALLBACK_PROVIDER=openai
OCR_LLM_FALLBACK_MODEL=gpt-4o

# Embeddings for RAG: openai | ollama
OCR_EMBEDDING_PROVIDER=openai
OCR_OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Ollama host. Outside Docker: http://localhost:11434
# Inside Docker reaching host Ollama: http://host.docker.internal:11434
# Remote Ollama: http://<server-ip>:11434
OCR_OLLAMA_BASE_URL=http://localhost:11434

# --- Fully-local example (no cloud keys needed) ---
# OCR_LLM_PROVIDER=ollama
# OCR_LLM_PRIMARY_MODEL=llama3.1
# OCR_LLM_FALLBACK_PROVIDER=ollama
# OCR_LLM_FALLBACK_MODEL=llama3.1
# OCR_EMBEDDING_PROVIDER=ollama
# OCR_PARSER_BACKEND=local

# --- LlamaParse ---
LLAMA_CLOUD_API_KEY=

# --- PII encryption (AES-256-GCM); 32-byte base64 key ---
OCR_PII_ENCRYPTION_KEY=
